# ===========================================
# Local Market Online Store - Environment Config
# ===========================================

# Server
PORT=3000

# MongoDB Connection String
# Replace with your MongoDB Atlas URI or local MongoDB URI
MONGODB_URI=mongodb://127.0.0.1:27017/local_market_store

# JWT Secret Key (change this in production!)
JWT_SECRET=local_market_super_secret_key_2024

# JWT Expiration
JWT_EXPIRES_IN=7d
